#!/usr/bin/env bash
set -u


die() {
  printf 'codex wrapper: %s\n' "$*" >&2
  exit 1
}


is_linux() {
  [ "$(uname -s 2>/dev/null)" = "Linux" ]
}


watch_requires_python3() {
  local shebang

  [ -n "${WATCH_BIN:-}" ] || return 1
  IFS= read -r shebang < "$WATCH_BIN" || return 1

  case "$shebang" in
    '#!'*python3*) return 0 ;;
    *) return 1 ;;
  esac
}


linux_install_command() {
  local packages=("$@")

  if [ "${EUID:-$(id -u)}" -eq 0 ]; then
    printf 'apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y'
  else
    printf 'sudo apt-get update && sudo env DEBIAN_FRONTEND=noninteractive apt-get install -y'
  fi

  printf ' %s' "${packages[@]}"
}


ensure_linux_dependencies() {
  local packages=()
  local choice
  local install_label
  local installer=()

  is_linux || return 0
  [ "${CODEX_LINUX_DEP_CHECK:-1}" != "0" ] || return 0

  if watch_requires_python3 && ! command -v python3 >/dev/null 2>&1; then
    packages+=(python3)
  fi

  if [ -z "${TMUX:-}" ] && [ -z "${CODEX_TMUX_BIN:-}" ] && \
     ! command -v tmux >/dev/null 2>&1; then
    packages+=(tmux)
  fi

  [ "${#packages[@]}" -gt 0 ] || return 0

  printf 'codex wrapper: missing Linux dependencies: %s\n' "${packages[*]}" >&2

  if ! command -v apt-get >/dev/null 2>&1; then
    die "automatic installation requires apt-get. Install manually: ${packages[*]}"
  fi

  if [ ! -t 0 ] || [ ! -t 1 ]; then
    die "cannot prompt in a non-interactive terminal. Run: $(linux_install_command "${packages[@]}")"
  fi

  if [ "${EUID:-$(id -u)}" -eq 0 ]; then
    install_label='apt-get'
  else
    command -v sudo >/dev/null 2>&1 || die "sudo was not found. Install manually: ${packages[*]}"
    install_label='sudo apt-get'
  fi

  printf 'Install them now with %s?\n' "$install_label" >&2
  printf '  y) yes\n' >&2
  printf '  n) no\n' >&2

  while true; do
    printf 'Select [n]: ' >&2
    IFS= read -r choice || choice=n

    case "$choice" in
      y|Y|yes|YES|Yes)
        break
        ;;
      ''|n|N|no|NO|No)
        die "dependencies were not installed. Run: $(linux_install_command "${packages[@]}")"
        ;;
      *)
        printf 'Enter y or n.\n' >&2
        ;;
    esac
  done

  if [ "${EUID:-$(id -u)}" -eq 0 ]; then
    installer=(apt-get)
  else
    installer=(sudo apt-get)
  fi

  "${installer[@]}" update || die "apt-get update failed"

  if [ "${EUID:-$(id -u)}" -eq 0 ]; then
    DEBIAN_FRONTEND=noninteractive apt-get install -y "${packages[@]}" ||
      die "dependency installation failed"
  else
    sudo env DEBIAN_FRONTEND=noninteractive apt-get install -y "${packages[@]}" ||
      die "dependency installation failed"
  fi

  if watch_requires_python3 && ! command -v python3 >/dev/null 2>&1; then
    die "python3 is still unavailable after installation"
  fi

  if [ -z "${TMUX:-}" ] && [ -z "${CODEX_TMUX_BIN:-}" ] && \
     ! command -v tmux >/dev/null 2>&1; then
    die "tmux is still unavailable after installation"
  fi

}


resolve_path() {
  local target=$1
  local dir

  while [ -L "$target" ]; do
    dir=$(cd -P -- "$(dirname -- "$target")" >/dev/null 2>&1 && pwd) || return 1
    target=$(readlink "$target") || return 1
    case "$target" in
      /*) ;;
      *) target="$dir/$target" ;;
    esac
  done

  dir=$(cd -P -- "$(dirname -- "$target")" >/dev/null 2>&1 && pwd) || return 1
  printf '%s/%s\n' "$dir" "$(basename -- "$target")"
}


script_path() {
  local source=${BASH_SOURCE[0]}

  case "$source" in
    /*) ;;
    */*) source="$PWD/$source" ;;
    *) source=$(command -v -- "$source") || return 1 ;;
  esac

  resolve_path "$source"
}


find_real_codex() {
  local old_ifs
  local dir
  local candidate
  local resolved

  if [ -n "${CODEX_REAL_BIN:-}" ]; then
    [ -x "$CODEX_REAL_BIN" ] || die "CODEX_REAL_BIN is not executable: $CODEX_REAL_BIN"
    printf '%s\n' "$CODEX_REAL_BIN"
    return 0
  fi

  old_ifs=$IFS
  IFS=:
  for dir in $PATH; do
    IFS=$old_ifs
    [ -n "$dir" ] || dir=.
    candidate="$dir/codex"

    if [ ! -f "$candidate" ] || [ ! -x "$candidate" ]; then
      IFS=:
      continue
    fi

    if [ "$candidate" -ef "$SELF" ]; then
      IFS=:
      continue
    fi

    resolved=$(resolve_path "$candidate" 2>/dev/null || printf '%s\n' "$candidate")
    if [ "$resolved" = "$SELF" ]; then
      IFS=:
      continue
    fi

    printf '%s\n' "$candidate"
    IFS=$old_ifs
    return 0
  done
  IFS=$old_ifs

  die "could not find the real codex binary. Set CODEX_REAL_BIN=/path/to/codex."
}


find_watch_bin() {
  local candidate

  if [ -n "${CODEX_WATCH_BIN:-}" ]; then
    [ -x "$CODEX_WATCH_BIN" ] || die "CODEX_WATCH_BIN is not executable: $CODEX_WATCH_BIN"
    printf '%s\n' "$CODEX_WATCH_BIN"
    return 0
  fi

  candidate="$SELF_DIR/codex-watch"
  if [ -x "$candidate" ]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  candidate=$(command -v codex-watch 2>/dev/null || true)
  if [ -n "$candidate" ] && [ -x "$candidate" ]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  die "could not find codex-watch. Install it next to this shim or set CODEX_WATCH_BIN."
}


find_tmux_bin() {
  local candidate
  local brew_prefix

  if [ -n "${CODEX_TMUX_BIN:-}" ]; then
    [ -x "$CODEX_TMUX_BIN" ] || die "CODEX_TMUX_BIN is not executable: $CODEX_TMUX_BIN"
    printf '%s\n' "$CODEX_TMUX_BIN"
    return 0
  fi

  candidate=$(command -v tmux 2>/dev/null || true)
  if [ -n "$candidate" ] && [ -x "$candidate" ]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  for candidate in \
    /opt/homebrew/bin/tmux \
    /opt/homebrew/opt/tmux/bin/tmux \
    /usr/local/bin/tmux \
    /usr/bin/tmux \
    /bin/tmux
  do
    if [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  if command -v brew >/dev/null 2>&1; then
    brew_prefix=$(brew --prefix tmux 2>/dev/null || true)
    candidate="$brew_prefix/bin/tmux"
    if [ -n "$brew_prefix" ] && [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  fi

  return 1
}


run_watched_codex() {
  if [ "${CODEX_WATCH_DISABLE:-0}" = "1" ]; then
    exec "$REAL_CODEX" "$@"
  fi

  exec "$WATCH_BIN" -- "$REAL_CODEX" "$@"
}


sh_quote() {
  local value=$1

  if [ -z "$value" ]; then
    printf "''"
    return 0
  fi

  printf "'"
  while [ -n "$value" ]; do
    case "$value" in
      *"'"*)
        printf "%s'\\''" "${value%%\'*}"
        value=${value#*\'}
        ;;
      *)
        printf "%s" "$value"
        value=
        ;;
    esac
  done
  printf "'"
}


env_is_set() {
  eval '[ "${'"$1"'+x}" = x ]'
}


env_value() {
  eval 'printf "%s" "${'"$1"'}"'
}


emit_env_assignment() {
  local name=$1
  local value

  if env_is_set "$name"; then
    value=$(env_value "$name")
    printf '%s=' "$name"
    sh_quote "$value"
    printf ' '
  fi
}


build_tmux_command() {
  local env_name

  printf 'CODEX_REAL_BIN='
  sh_quote "$REAL_CODEX"
  printf ' '

  if [ -n "${TMUX_BIN:-}" ]; then
    printf 'CODEX_TMUX_BIN='
    sh_quote "$TMUX_BIN"
    printf ' '
    printf 'CODEX_WATCH_TMUX_BIN='
    sh_quote "$TMUX_BIN"
    printf ' '
  fi

  if [ -n "${WATCH_BIN:-}" ]; then
    printf 'CODEX_WATCH_BIN='
    sh_quote "$WATCH_BIN"
    printf ' '
  fi

  for env_name in \
    CODEX_WATCH_MATCH \
    CODEX_WATCH_PATTERN \
    CODEX_WATCH_REPLY \
    CODEX_WATCH_SUBMIT_KEY \
    CODEX_WATCH_COOLDOWN \
    CODEX_WATCH_MAX_UNFREEZES \
    CODEX_WATCH_WINDOW \
    CODEX_WATCH_IDLE \
    CODEX_WATCH_BUFFER \
    CODEX_WATCH_NO_SAFETY_CHECK_RETURN \
    CODEX_WATCH_SAFETY_CHECK_COOLDOWN \
    CODEX_WATCH_NO_TMUX_DETACH_HOTKEY \
    CODEX_WATCH_DISABLE \
    CODEX_LINUX_DEP_CHECK
  do
    emit_env_assignment "$env_name"
  done

  sh_quote "$SELF"

  local arg
  for arg in "$@"; do
    printf ' '
    sh_quote "$arg"
  done
}


session_exists() {
  "$TMUX_BIN" has-session -t "=$1" 2>/dev/null
}


next_session_name() {
  local base=$1
  local candidate
  local index=2

  while true; do
    candidate="${base}-${index}"
    if ! session_exists "$candidate"; then
      printf '%s\n' "$candidate"
      return
    fi
    index=$((index + 1))
  done
}


start_new_tmux_session() {
  local session_name=$1
  local session_dir=$2
  local command
  shift 2

  command=$(build_tmux_command "$@")
  exec "$TMUX_BIN" new-session -s "$session_name" -c "$session_dir" "$command"
}


choose_existing_session() {
  local session_name=$1
  local choice

  printf "Codex tmux session '%s' is already running.\n" "$session_name"

  while true; do
    printf 'Attach to it or create a new one? [A/n/q] '
    IFS= read -r choice || choice=a

    case "${choice:-a}" in
      a|A|[aA][tT][tT][aA][cC][hH])
        exec "$TMUX_BIN" attach-session -t "=$session_name"
        ;;
      n|N|[nN][eE][wW])
        return 0
        ;;
      q|Q|[qQ][uU][iI][tT])
        exit 0
        ;;
      *)
        printf "Please choose 'a' to attach, 'n' for new, or 'q' to quit.\n" >&2
        ;;
    esac
  done
}


SELF=$(script_path)
SELF_DIR=$(dirname -- "$SELF")
REAL_CODEX=$(find_real_codex) || exit $?
WATCH_BIN=
if [ "${CODEX_WATCH_DISABLE:-0}" != "1" ]; then
  WATCH_BIN=$(find_watch_bin) || exit $?
fi

ensure_linux_dependencies

if [ -n "${TMUX:-}" ]; then
  run_watched_codex "$@"
fi

TMUX_BIN=$(find_tmux_bin)
tmux_find_status=$?
if [ "$tmux_find_status" -ne 0 ]; then
  if [ -n "${CODEX_TMUX_BIN:-}" ]; then
    exit "$tmux_find_status"
  fi
  TMUX_BIN=
fi
if [ -z "$TMUX_BIN" ]; then
  die "tmux is required. Install tmux or set CODEX_TMUX_BIN=/path/to/tmux."
fi

SESSION_DIR=${CODEX_TMUX_DIR:-$PWD}
SESSION_NAME=${CODEX_TMUX_SESSION:-codex-$(basename "$SESSION_DIR")}
SESSION_NAME=$(printf '%s' "$SESSION_NAME" | tr -c '[:alnum:]_.-' '-')

if [ "$#" -gt 0 ]; then
  if session_exists "$SESSION_NAME"; then
    SESSION_NAME=$(next_session_name "$SESSION_NAME")
  fi
  start_new_tmux_session "$SESSION_NAME" "$SESSION_DIR" "$@"
fi

if session_exists "$SESSION_NAME"; then
  if [ -t 0 ] && [ -t 1 ]; then
    choose_existing_session "$SESSION_NAME"
    SESSION_NAME=$(next_session_name "$SESSION_NAME")
  else
    exec "$TMUX_BIN" attach-session -t "=$SESSION_NAME"
  fi
fi

start_new_tmux_session "$SESSION_NAME" "$SESSION_DIR"
