#!/usr/bin/env python3
# Edit these values.
#
# TYPE_IN is sent to the child process followed by SUBMIT_KEY.
# WHEN_OUTPUT_CONTAINS is a plain substring match against terminal output. It is
# not a regex.
TYPE_IN = "/goal resume"
WHEN_OUTPUT_CONTAINS = "Goal blocked"
SUBMIT_KEY = "ctrl-m"

# Treat repeated unfreezes as a bug, not as normal operation.
MIN_SECONDS_BETWEEN_UNFREEZES = 30
MAX_UNFREEZES_PER_WINDOW = 3
UNFREEZE_WINDOW_SECONDS = 600

# Fallback tmux detach hotkey. Normally tmux catches Ctrl-b then d itself; this
# handles cases where those bytes reach codex-watch instead.
ENABLE_CTRL_B_D_TMUX_DETACH = True
CTRL_B_D_TIMEOUT_SECONDS = 1.0

import argparse
import codecs
import errno
import fcntl
import os
import pty
import re
import select
import signal
import subprocess
import sys
import termios
import time
import tty


ANSI_RE = re.compile(
    r"\x1b\[[0-?]*[ -/]*[@-~]|"        # CSI
    r"\x1b\][^\x07]*(?:\x07|\x1b\\)|"  # OSC
    r"\x1b[@-Z\\-_]"                   # 2-byte escapes
)


def strip_ansi(text: str) -> str:
    return ANSI_RE.sub("", text)


def env_or_default(name: str, default: str) -> str:
    return os.getenv(name) if name in os.environ else default


def env_float(name: str, default: float) -> float:
    return float(os.getenv(name, str(default)))


def env_int(name: str, default: int) -> int:
    return int(os.getenv(name, str(default)))


def env_bool(name: str, default: bool) -> bool:
    value = os.getenv(name)
    if value is None:
        return default
    return value.lower() not in {"", "0", "false", "no", "off"}


def submit_key_sequence(key_name: str) -> bytes:
    stripped = key_name.strip()

    if stripped.lower().startswith("raw:"):
        return codecs.decode(stripped[4:], "unicode_escape").encode()

    normalized = stripped.lower()

    if normalized in {"", "none", "off"}:
        return b""
    if normalized in {"enter", "return", "cr"}:
        return b"\r"
    if normalized in {"lf", "linefeed"}:
        return b"\n"
    if normalized.startswith("ctrl-") and len(normalized) == len("ctrl-a"):
        char = normalized[-1]
        if "a" <= char <= "z":
            return bytes([ord(char) - ord("a") + 1])
    if normalized == "ctrl-enter":
        return b"\x1b[13;5u"
    if normalized == "shift-enter":
        return b"\x1b[13;2u"
    if normalized == "alt-enter":
        return b"\x1b[13;3u"
    if normalized == "ctrl-shift-enter":
        return b"\x1b[13;6u"
    raise ValueError(
        "invalid submit key: "
        f"{key_name!r}; use enter, ctrl-enter, shift-enter, alt-enter, "
        "ctrl-shift-enter, ctrl-a through ctrl-z, none, or raw:<escaped-bytes>"
    )


def parse_args():
    parser = argparse.ArgumentParser(
        description=(
            "Run an interactive command in a PTY and auto-send input when "
            "output matches configured text or a regex."
        )
    )
    parser.add_argument(
        "--match",
        default=env_or_default("CODEX_WATCH_MATCH", WHEN_OUTPUT_CONTAINS),
        help=(
            "Plain output text to watch for. Defaults to CODEX_WATCH_MATCH "
            "or WHEN_OUTPUT_CONTAINS."
        ),
    )
    parser.add_argument(
        "--pattern",
        default=os.getenv("CODEX_WATCH_PATTERN", ""),
        help="Regex to watch for in addition to --match. Defaults to CODEX_WATCH_PATTERN.",
    )
    parser.add_argument(
        "--reply",
        default=env_or_default("CODEX_WATCH_REPLY", TYPE_IN),
        help="Input to send when triggered. Defaults to CODEX_WATCH_REPLY or TYPE_IN.",
    )
    parser.add_argument(
        "--submit-key",
        default=env_or_default("CODEX_WATCH_SUBMIT_KEY", SUBMIT_KEY),
        help="Key sequence sent after --reply. Defaults to CODEX_WATCH_SUBMIT_KEY or SUBMIT_KEY.",
    )
    parser.add_argument(
        "--cooldown",
        type=float,
        default=env_float("CODEX_WATCH_COOLDOWN", MIN_SECONDS_BETWEEN_UNFREEZES),
        help="Minimum seconds between automatic replies.",
    )
    parser.add_argument(
        "--max-unfreezes",
        type=int,
        default=env_int("CODEX_WATCH_MAX_UNFREEZES", MAX_UNFREEZES_PER_WINDOW),
        help="Maximum automatic replies allowed within --window. Use 0 to disable.",
    )
    parser.add_argument(
        "--window",
        type=float,
        default=env_float("CODEX_WATCH_WINDOW", UNFREEZE_WINDOW_SECONDS),
        help="Seconds used for the repeated-unfreeze circuit breaker.",
    )
    parser.add_argument(
        "--idle",
        type=float,
        default=env_float("CODEX_WATCH_IDLE", 0),
        help="Also send the reply after this many seconds without output. Disabled at 0.",
    )
    parser.add_argument(
        "--buffer",
        type=int,
        default=env_int("CODEX_WATCH_BUFFER", 65536),
        help="Number of recent output characters to keep for regex matching.",
    )
    parser.add_argument(
        "--no-strip-ansi",
        action="store_true",
        help="Match the regex against raw terminal output including ANSI escapes.",
    )
    parser.add_argument(
        "--no-tmux-detach-hotkey",
        action="store_true",
        default=env_bool("CODEX_WATCH_NO_TMUX_DETACH_HOTKEY", False),
        help="Do not intercept Ctrl-b then d as tmux detach inside tmux.",
    )
    parser.add_argument("cmd", nargs=argparse.REMAINDER)

    args = parser.parse_args()

    if args.cmd and args.cmd[0] == "--":
        args.cmd = args.cmd[1:]

    if not args.cmd:
        args.cmd = ["codex"]

    return args


def exit_code_from_status(status: int) -> int:
    if os.WIFEXITED(status):
        return os.WEXITSTATUS(status)
    if os.WIFSIGNALED(status):
        return 128 + os.WTERMSIG(status)
    return 1


def main() -> int:
    args = parse_args()

    try:
        submit_sequence = submit_key_sequence(args.submit_key)
    except ValueError as e:
        print(f"codex-watch: {e}", file=sys.stderr)
        return 2

    stdin_fd = sys.stdin.fileno()
    stdout_fd = sys.stdout.fileno()

    pid, master_fd = pty.fork()

    if pid == 0:
        os.execvp(args.cmd[0], args.cmd)

    old_term = None

    if os.isatty(stdin_fd):
        old_term = termios.tcgetattr(stdin_fd)
        tty.setraw(stdin_fd)

    def resize_child(_signum=None, _frame=None):
        if not os.isatty(stdin_fd):
            return
        try:
            size = fcntl.ioctl(stdin_fd, termios.TIOCGWINSZ, b"\0" * 8)
            fcntl.ioctl(master_fd, termios.TIOCSWINSZ, size)
        except OSError:
            pass

    signal.signal(signal.SIGWINCH, resize_child)
    resize_child()

    pattern = re.compile(args.pattern, re.IGNORECASE | re.DOTALL) if args.pattern else None
    match_text = args.match
    recent = ""
    match_latched = False
    latched_notice_sent = False
    last_sent = 0.0
    last_output = time.monotonic()
    reply_times = []
    circuit_breaker_open = False
    pending_match_reason = ""
    pending_match_due = 0.0
    tmux_bin = os.getenv("CODEX_WATCH_TMUX_BIN", "tmux")
    tmux_detach_hotkey_enabled = (
        ENABLE_CTRL_B_D_TMUX_DETACH
        and not args.no_tmux_detach_hotkey
        and bool(os.getenv("TMUX"))
    )
    tmux_prefix_pending = False
    tmux_prefix_pending_at = 0.0

    def current_match_reason(buffer: str) -> str:
        if pattern and pattern.search(buffer):
            return "regex matched"
        if match_text and match_text in buffer:
            return "text matched"
        return ""

    def notice(message: str):
        os.write(stdout_fd, f"\r\n[codex-watch: {message}]\r\n".encode())

    def clear_pending_match():
        nonlocal pending_match_reason, pending_match_due

        pending_match_reason = ""
        pending_match_due = 0.0

    def schedule_pending_match(reason: str, retry_at: float):
        nonlocal pending_match_reason, pending_match_due

        if retry_at <= time.monotonic():
            return

        pending_match_reason = reason
        pending_match_due = retry_at

    def detach_tmux_client() -> bool:
        try:
            result = subprocess.run(
                [tmux_bin, "detach-client"],
                stdin=subprocess.DEVNULL,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                timeout=2,
                check=False,
            )
        except (OSError, subprocess.TimeoutExpired):
            notice("tmux detach failed")
            return False

        if result.returncode != 0:
            notice("tmux detach failed")
            return False

        notice("detached tmux client")
        return True

    def flush_pending_tmux_prefix_if_stale():
        nonlocal tmux_prefix_pending

        if (
            tmux_prefix_pending
            and time.monotonic() - tmux_prefix_pending_at >= CTRL_B_D_TIMEOUT_SECONDS
        ):
            try:
                os.write(master_fd, b"\x02")
            except OSError as e:
                if e.errno not in (errno.EIO, errno.EBADF):
                    raise
            tmux_prefix_pending = False

    def forward_stdin(data: bytes):
        nonlocal tmux_prefix_pending, tmux_prefix_pending_at

        if not tmux_detach_hotkey_enabled:
            os.write(master_fd, data)
            return

        flush_pending_tmux_prefix_if_stale()

        pending = bytearray()

        for byte in data:
            if tmux_prefix_pending:
                if byte == ord("d"):
                    if pending:
                        os.write(master_fd, bytes(pending))
                        pending.clear()
                    detach_tmux_client()
                    tmux_prefix_pending = False
                    continue

                pending.append(0x02)
                tmux_prefix_pending = False

            if byte == 0x02:
                if pending:
                    os.write(master_fd, bytes(pending))
                    pending.clear()
                tmux_prefix_pending = True
                tmux_prefix_pending_at = time.monotonic()
                continue

            pending.append(byte)

        if pending:
            os.write(master_fd, bytes(pending))

    def send_reply(reason: str):
        nonlocal circuit_breaker_open, last_sent, last_output, reply_times

        now = time.monotonic()

        if now - last_sent < args.cooldown:
            remaining = args.cooldown - (now - last_sent)
            notice(f"suppressed reply: cooldown active for {remaining:.1f}s")
            return False, last_sent + args.cooldown

        if args.max_unfreezes > 0 and args.window > 0:
            reply_times = [sent_at for sent_at in reply_times if now - sent_at < args.window]

            if len(reply_times) >= args.max_unfreezes:
                if not circuit_breaker_open:
                    notice(
                        "circuit breaker open: repeated unfreezes look like a bug; "
                        "not auto-sending"
                    )
                circuit_breaker_open = True
                return False, min(reply_times) + args.window

        circuit_breaker_open = False

        payload = args.reply.encode(errors="ignore") + submit_sequence
        try:
            os.write(master_fd, payload)
        except OSError as e:
            if e.errno in (errno.EIO, errno.EBADF):
                return False, 0.0
            raise

        last_sent = now
        last_output = now
        reply_times.append(now)

        notice(f"auto-sent reply: {reason}")
        return True, last_sent + args.cooldown

    def send_or_schedule_match(reason: str):
        sent, retry_at = send_reply(reason)
        if retry_at > 0:
            schedule_pending_match(reason, retry_at)
        if sent:
            return True
        return False

    try:
        while True:
            read_fds = [master_fd]

            if os.isatty(stdin_fd):
                read_fds.append(stdin_fd)

            ready, _, _ = select.select(read_fds, [], [], 1.0)

            if master_fd in ready:
                try:
                    data = os.read(master_fd, 8192)
                except OSError as e:
                    if e.errno == errno.EIO:
                        break
                    raise

                if not data:
                    break

                os.write(stdout_fd, data)
                last_output = time.monotonic()

                text = data.decode(errors="ignore")

                if not args.no_strip_ansi:
                    text = strip_ansi(text)

                recent = (recent + text)[-args.buffer:]
                reason = current_match_reason(recent)

                if reason:
                    if not match_latched:
                        send_or_schedule_match(reason)
                        latched_notice_sent = False
                    elif not latched_notice_sent:
                        if pending_match_reason:
                            notice("suppressed reply: match still latched; retry scheduled")
                        else:
                            notice("suppressed reply: match still latched")
                        latched_notice_sent = True
                    match_latched = True
                    recent = ""
                elif match_latched and text.strip():
                    match_latched = False
                    latched_notice_sent = False
                    clear_pending_match()

            if stdin_fd in ready:
                data = os.read(stdin_fd, 8192)
                if data:
                    forward_stdin(data)

            flush_pending_tmux_prefix_if_stale()

            if pending_match_reason and time.monotonic() >= pending_match_due:
                reason = pending_match_reason
                clear_pending_match()
                send_or_schedule_match(reason)
                match_latched = True
                latched_notice_sent = False

            if args.idle > 0 and time.monotonic() - last_output >= args.idle:
                send_reply(f"idle {int(args.idle)}s")

            try:
                done_pid, status = os.waitpid(pid, os.WNOHANG)
                if done_pid == pid:
                    return exit_code_from_status(status)
            except ChildProcessError:
                break

    finally:
        if old_term is not None:
            termios.tcsetattr(stdin_fd, termios.TCSADRAIN, old_term)

    try:
        _, status = os.waitpid(pid, 0)
        return exit_code_from_status(status)
    except ChildProcessError:
        return 0


if __name__ == "__main__":
    raise SystemExit(main())
