#!/usr/bin/env python3
# codex-antifreeze-wrapper managed watcher
# Edit these values.
#
# TYPE_IN is sent to the child process followed by SUBMIT_KEY.
# WHEN_OUTPUT_CONTAINS is a plain substring match against terminal output. It is
# not a regex.
TYPE_IN = "/goal resume"
WHEN_OUTPUT_CONTAINS = "Goal blocked"
SUBMIT_KEY = "ctrl-m"
USE_BRACKETED_PASTE = True
TYPE_KEY_DELAY_SECONDS = 0.015
SUBMIT_DELAY_SECONDS = 0.15

# This prompt is independent of the normal match/reply mode. When every part is
# present in recent terminal output, use arrow keys to select "Keep waiting"
# before sending Return.
SAFETY_CHECK_PROMPT_PARTS = (
    "Additional safety checks",
    "This request requires additional safety checks, which can take extra time.",
    "Keep waiting",
)
AUTO_RETURN_SAFETY_CHECKS = True
SAFETY_CHECK_COOLDOWN_SECONDS = 4
SAFETY_CHECK_MENU_MAX_OPTIONS = 3
SAFETY_CHECK_SCREEN_SETTLE_SECONDS = 0.04
SAFETY_CHECK_CONFIRM_TIMEOUT_SECONDS = 2.0
SAFETY_CHECK_DISMISS_CONFIRM_SECONDS = 0.15

# Runtime messages must not be written into Codex's full-screen terminal UI.
# Set CODEX_WATCH_LOG to a file path if diagnostic messages are needed.
RUNTIME_LOG_FILE = ""

MIN_SECONDS_BETWEEN_UNFREEZES = 4
MAX_UNFREEZES_PER_WINDOW = 0
UNFREEZE_WINDOW_SECONDS = 600

# Fallback tmux detach hotkey. Normally tmux catches Ctrl-b then d itself; this
# handles cases where those bytes reach codex-watch instead.
ENABLE_CTRL_B_D_TMUX_DETACH = True
CTRL_B_D_TIMEOUT_SECONDS = 1.0

import argparse
import codecs
import errno
import fcntl
import os
import pty
import re
import select
import signal
import subprocess
import sys
import termios
import time
import tty


ANSI_RE = re.compile(
    r"\x1b\[[0-?]*[ -/]*[@-~]|"        # CSI
    r"\x1b\][^\x07]*(?:\x07|\x1b\\)|"  # OSC
    r"\x1b[@-Z\\-_]"                   # 2-byte escapes
)
KEEP_WAITING_OPTION_RE = re.compile(r"(?<!\d)(\d+)\.\s*Keep waiting\b")
ACTIVE_OPTION_RE = re.compile(r"›\s*(\d+)\.\s*[^\r\n]+")
ACTIVE_KEEP_WAITING_OPTION_RE = re.compile(r"›\s*(\d+)\.\s*Keep waiting\b")
ARROW_UP_SEQUENCE = b"\x1b[A"
ARROW_DOWN_SEQUENCE = b"\x1b[B"
RETURN_SEQUENCE = b"\r"


def strip_ansi(text: str) -> str:
    return ANSI_RE.sub("", text)


def safety_check_option_indices(buffer: str):
    prompt_start = buffer.rfind("Additional safety checks")
    if prompt_start < 0:
        return None

    prompt = buffer[prompt_start:]
    keep_waiting_matches = KEEP_WAITING_OPTION_RE.findall(prompt)
    active_matches = ACTIVE_OPTION_RE.findall(prompt)
    if not keep_waiting_matches or not active_matches:
        return None

    active_index = int(active_matches[-1])
    keep_waiting_index = int(keep_waiting_matches[-1])
    if not (
        1 <= active_index <= SAFETY_CHECK_MENU_MAX_OPTIONS
        and 1 <= keep_waiting_index <= SAFETY_CHECK_MENU_MAX_OPTIONS
    ):
        return None
    return active_index, keep_waiting_index


def latest_active_option_index(buffer: str):
    matches = ACTIVE_OPTION_RE.findall(buffer)
    return int(matches[-1]) if matches else None


def latest_active_keep_waiting_index(buffer: str):
    matches = ACTIVE_KEEP_WAITING_OPTION_RE.findall(buffer)
    return int(matches[-1]) if matches else None


def keep_waiting_key_sequence(active_index: int, keep_waiting_index: int):
    if not (
        1 <= active_index <= SAFETY_CHECK_MENU_MAX_OPTIONS
        and 1 <= keep_waiting_index <= SAFETY_CHECK_MENU_MAX_OPTIONS
    ):
        raise ValueError(
            "invalid safety-check option indices: "
            f"active={active_index}, keep_waiting={keep_waiting_index}"
        )

    if active_index < keep_waiting_index:
        navigation = [ARROW_DOWN_SEQUENCE] * (keep_waiting_index - active_index)
    else:
        navigation = [ARROW_UP_SEQUENCE] * (active_index - keep_waiting_index)
    return navigation + [RETURN_SEQUENCE]


def env_or_default(name: str, default: str) -> str:
    return os.getenv(name) if name in os.environ else default


def env_float(name: str, default: float) -> float:
    return float(os.getenv(name, str(default)))


def env_int(name: str, default: int) -> int:
    return int(os.getenv(name, str(default)))


def env_bool(name: str, default: bool) -> bool:
    value = os.getenv(name)
    if value is None:
        return default
    return value.lower() not in {"", "0", "false", "no", "off"}


def submit_key_sequence(key_name: str) -> bytes:
    stripped = key_name.strip()

    if stripped.lower().startswith("raw:"):
        return codecs.decode(stripped[4:], "unicode_escape").encode()

    normalized = stripped.lower()

    if normalized in {"", "none", "off"}:
        return b""
    if normalized in {"enter", "return", "cr"}:
        return b"\r"
    if normalized in {"lf", "linefeed"}:
        return b"\n"
    if normalized.startswith("ctrl-") and len(normalized) == len("ctrl-a"):
        char = normalized[-1]
        if "a" <= char <= "z":
            return bytes([ord(char) - ord("a") + 1])
    if normalized == "ctrl-enter":
        return b"\x1b[13;5u"
    if normalized == "shift-enter":
        return b"\x1b[13;2u"
    if normalized == "alt-enter":
        return b"\x1b[13;3u"
    if normalized == "ctrl-shift-enter":
        return b"\x1b[13;6u"
    raise ValueError(
        "invalid submit key: "
        f"{key_name!r}; use enter, ctrl-enter, shift-enter, alt-enter, "
        "ctrl-shift-enter, ctrl-a through ctrl-z, none, or raw:<escaped-bytes>"
    )


def parse_args():
    parser = argparse.ArgumentParser(
        description=(
            "Run an interactive command in a PTY and auto-send input when "
            "output matches configured text or a regex."
        )
    )
    parser.add_argument(
        "--match",
        default=env_or_default("CODEX_WATCH_MATCH", WHEN_OUTPUT_CONTAINS),
        help=(
            "Plain output text to watch for. Defaults to CODEX_WATCH_MATCH "
            "or WHEN_OUTPUT_CONTAINS."
        ),
    )
    parser.add_argument(
        "--pattern",
        default=os.getenv("CODEX_WATCH_PATTERN", ""),
        help="Regex to watch for in addition to --match. Defaults to CODEX_WATCH_PATTERN.",
    )
    parser.add_argument(
        "--reply",
        default=env_or_default("CODEX_WATCH_REPLY", TYPE_IN),
        help="Input to send when triggered. Defaults to CODEX_WATCH_REPLY or TYPE_IN.",
    )
    parser.add_argument(
        "--submit-key",
        default=env_or_default("CODEX_WATCH_SUBMIT_KEY", SUBMIT_KEY),
        help="Key sequence sent after --reply. Defaults to CODEX_WATCH_SUBMIT_KEY or SUBMIT_KEY.",
    )
    parser.add_argument(
        "--no-bracketed-paste",
        action="store_true",
        default=env_bool("CODEX_WATCH_NO_BRACKETED_PASTE", not USE_BRACKETED_PASTE),
        help="Type --reply as key bytes instead of using terminal bracketed paste.",
    )
    parser.add_argument(
        "--type-delay",
        type=float,
        default=env_float("CODEX_WATCH_TYPE_DELAY", TYPE_KEY_DELAY_SECONDS),
        help=(
            "Seconds to wait between bytes of --reply. Defaults to "
            "CODEX_WATCH_TYPE_DELAY or TYPE_KEY_DELAY_SECONDS."
        ),
    )
    parser.add_argument(
        "--submit-delay",
        type=float,
        default=env_float("CODEX_WATCH_SUBMIT_DELAY", SUBMIT_DELAY_SECONDS),
        help=(
            "Seconds to wait between --reply and --submit-key. Defaults to "
            "CODEX_WATCH_SUBMIT_DELAY or SUBMIT_DELAY_SECONDS."
        ),
    )
    parser.add_argument(
        "--cooldown",
        type=float,
        default=env_float("CODEX_WATCH_COOLDOWN", MIN_SECONDS_BETWEEN_UNFREEZES),
        help="Minimum seconds between automatic replies.",
    )
    parser.add_argument(
        "--max-unfreezes",
        type=int,
        default=env_int("CODEX_WATCH_MAX_UNFREEZES", MAX_UNFREEZES_PER_WINDOW),
        help="Maximum automatic replies allowed within --window. Use 0 to disable.",
    )
    parser.add_argument(
        "--window",
        type=float,
        default=env_float("CODEX_WATCH_WINDOW", UNFREEZE_WINDOW_SECONDS),
        help="Seconds used for the repeated-unfreeze circuit breaker when --max-unfreezes is above 0.",
    )
    parser.add_argument(
        "--idle",
        type=float,
        default=env_float("CODEX_WATCH_IDLE", 0),
        help="Also send the reply after this many seconds without output. Disabled at 0.",
    )
    parser.add_argument(
        "--no-safety-check-return",
        action="store_true",
        default=env_bool(
            "CODEX_WATCH_NO_SAFETY_CHECK_RETURN", not AUTO_RETURN_SAFETY_CHECKS
        ),
        help=(
            "Do not select Keep waiting when the complete "
            "additional-safety-checks prompt is detected."
        ),
    )
    parser.add_argument(
        "--safety-check-cooldown",
        type=float,
        default=env_float(
            "CODEX_WATCH_SAFETY_CHECK_COOLDOWN", SAFETY_CHECK_COOLDOWN_SECONDS
        ),
        help=(
            "Minimum seconds between automatic Keep waiting selections. "
            "Prompts detected during the cooldown are left for manual input."
        ),
    )
    parser.add_argument(
        "--buffer",
        type=int,
        default=env_int("CODEX_WATCH_BUFFER", 65536),
        help="Number of recent output characters to keep for regex matching.",
    )
    parser.add_argument(
        "--no-strip-ansi",
        action="store_true",
        help="Match the regex against raw terminal output including ANSI escapes.",
    )
    parser.add_argument(
        "--no-tmux-detach-hotkey",
        action="store_true",
        default=env_bool("CODEX_WATCH_NO_TMUX_DETACH_HOTKEY", False),
        help="Do not intercept Ctrl-b then d as tmux detach inside tmux.",
    )
    parser.add_argument(
        "--log-file",
        default=env_or_default("CODEX_WATCH_LOG", RUNTIME_LOG_FILE),
        help=(
            "Append watcher diagnostics to this file. Diagnostics are silent by "
            "default so they cannot corrupt the Codex terminal UI."
        ),
    )
    parser.add_argument("cmd", nargs=argparse.REMAINDER)

    args = parser.parse_args()

    if args.cmd and args.cmd[0] == "--":
        args.cmd = args.cmd[1:]

    if not args.cmd:
        args.cmd = ["codex"]

    return args


def exit_code_from_status(status: int) -> int:
    if os.WIFEXITED(status):
        return os.WEXITSTATUS(status)
    if os.WIFSIGNALED(status):
        return 128 + os.WTERMSIG(status)
    return 1


def main() -> int:
    args = parse_args()

    try:
        submit_sequence = submit_key_sequence(args.submit_key)
    except ValueError as e:
        print(f"codex-watch: {e}", file=sys.stderr)
        return 2

    try:
        pattern = (
            re.compile(args.pattern, re.IGNORECASE | re.DOTALL)
            if args.pattern
            else None
        )
    except re.error as e:
        print(f"codex-watch: invalid --pattern: {e}", file=sys.stderr)
        return 2

    match_text = args.match

    stdin_fd = sys.stdin.fileno()
    stdout_fd = sys.stdout.fileno()

    pid, master_fd = pty.fork()

    if pid == 0:
        os.execvp(args.cmd[0], args.cmd)

    old_term = None

    if os.isatty(stdin_fd):
        old_term = termios.tcgetattr(stdin_fd)
        tty.setraw(stdin_fd)

    def resize_child(_signum=None, _frame=None):
        if not os.isatty(stdin_fd):
            return
        try:
            size = fcntl.ioctl(stdin_fd, termios.TIOCGWINSZ, b"\0" * 8)
            fcntl.ioctl(master_fd, termios.TIOCSWINSZ, size)
        except OSError:
            pass

    def forward_termination(signum, _frame=None):
        try:
            os.kill(pid, signum)
        except ProcessLookupError:
            pass

    signal.signal(signal.SIGWINCH, resize_child)
    for termination_signal in (signal.SIGHUP, signal.SIGINT, signal.SIGTERM):
        signal.signal(termination_signal, forward_termination)
    resize_child()

    recent = ""
    safety_raw_recent = ""
    safety_recent = ""
    match_latched = False
    latched_notice_sent = False
    match_probe_due = 0.0
    match_absent_since = None
    last_sent = 0.0
    last_output = time.monotonic()
    reply_times = []
    circuit_breaker_open = False
    last_safety_return = None
    output_decoder = codecs.getincrementaldecoder("utf-8")(errors="ignore")
    tmux_bin = os.getenv("CODEX_WATCH_TMUX_BIN", "tmux")
    tmux_pane = os.getenv("TMUX_PANE", "") if os.getenv("TMUX") else ""
    tmux_detach_hotkey_enabled = (
        ENABLE_CTRL_B_D_TMUX_DETACH
        and not args.no_tmux_detach_hotkey
        and bool(os.getenv("TMUX"))
    )
    tmux_prefix_pending = False
    tmux_prefix_pending_at = 0.0
    safety_state = "armed"
    safety_probe_due = 0.0
    safety_confirmation_deadline = 0.0
    safety_current_index = None
    safety_expected_index = None
    safety_target_index = None
    safety_confirmation_raw_recent = ""
    safety_confirmation_recent = ""
    safety_output_generation = 0
    safety_action_output_generation = 0
    safety_absent_since = None

    def current_match_reason(buffer: str) -> str:
        if pattern and pattern.search(buffer):
            return "regex matched"
        if match_text and match_text in buffer:
            return "text matched"
        return ""

    def safety_check_prompt_present(buffer: str) -> bool:
        return all(part in buffer for part in SAFETY_CHECK_PROMPT_PARTS)

    def notice(message: str):
        if not args.log_file:
            return

        try:
            with open(args.log_file, "a", encoding="utf-8") as log:
                timestamp = time.strftime("%Y-%m-%d %H:%M:%S")
                log.write(f"{timestamp} codex-watch: {message}\n")
        except OSError:
            # Diagnostics must never interfere with the interactive child.
            pass

    def schedule_match_probe(delay: float = SAFETY_CHECK_SCREEN_SETTLE_SECONDS):
        nonlocal match_probe_due

        if not tmux_pane or args.no_strip_ansi:
            return

        due = time.monotonic() + max(0.0, delay)
        if match_probe_due == 0.0 or due < match_probe_due:
            match_probe_due = due

    def detach_tmux_client() -> bool:
        try:
            result = subprocess.run(
                [tmux_bin, "detach-client"],
                stdin=subprocess.DEVNULL,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                timeout=2,
                check=False,
            )
        except (OSError, subprocess.TimeoutExpired):
            notice("tmux detach failed")
            return False

        if result.returncode != 0:
            notice("tmux detach failed")
            return False

        notice("detached tmux client")
        return True

    def flush_pending_tmux_prefix_if_stale():
        nonlocal tmux_prefix_pending

        if (
            tmux_prefix_pending
            and time.monotonic() - tmux_prefix_pending_at >= CTRL_B_D_TIMEOUT_SECONDS
        ):
            try:
                os.write(master_fd, b"\x02")
            except OSError as e:
                if e.errno not in (errno.EIO, errno.EBADF):
                    raise
            tmux_prefix_pending = False

    def forward_stdin(data: bytes):
        nonlocal tmux_prefix_pending, tmux_prefix_pending_at

        if not tmux_detach_hotkey_enabled:
            os.write(master_fd, data)
            return

        flush_pending_tmux_prefix_if_stale()

        pending = bytearray()

        for byte in data:
            if tmux_prefix_pending:
                if byte == ord("d"):
                    if pending:
                        os.write(master_fd, bytes(pending))
                        pending.clear()
                    detach_tmux_client()
                    tmux_prefix_pending = False
                    continue

                pending.append(0x02)
                tmux_prefix_pending = False

            if byte == 0x02:
                if pending:
                    os.write(master_fd, bytes(pending))
                    pending.clear()
                tmux_prefix_pending = True
                tmux_prefix_pending_at = time.monotonic()
                continue

            pending.append(byte)

        if pending:
            os.write(master_fd, bytes(pending))

    def send_reply(reason: str):
        nonlocal circuit_breaker_open, last_sent, last_output, reply_times

        now = time.monotonic()

        if now - last_sent < args.cooldown:
            remaining = args.cooldown - (now - last_sent)
            notice(f"suppressed reply: cooldown active for {remaining:.1f}s")
            return False

        if args.max_unfreezes > 0 and args.window > 0:
            reply_times = [sent_at for sent_at in reply_times if now - sent_at < args.window]

            if len(reply_times) >= args.max_unfreezes:
                if not circuit_breaker_open:
                    notice(
                        "circuit breaker open: repeated unfreezes look like a bug; "
                        "not auto-sending"
                    )
                circuit_breaker_open = True
                return False

        circuit_breaker_open = False

        try:
            reply = args.reply.encode(errors="ignore")
            if reply and not args.no_bracketed_paste:
                os.write(master_fd, b"\x1b[200~" + reply + b"\x1b[201~")
            elif args.type_delay > 0:
                for byte in reply:
                    os.write(master_fd, bytes([byte]))
                    time.sleep(args.type_delay)
            elif reply:
                os.write(master_fd, reply)

            if submit_sequence:
                if reply and args.submit_delay > 0:
                    time.sleep(args.submit_delay)
                os.write(master_fd, submit_sequence)
        except OSError as e:
            if e.errno in (errno.EIO, errno.EBADF):
                return False
            raise

        last_sent = now
        last_output = now
        reply_times.append(now)

        notice(f"auto-sent reply: {reason}")
        return True

    def schedule_safety_probe(delay: float = SAFETY_CHECK_SCREEN_SETTLE_SECONDS):
        nonlocal safety_probe_due

        due = time.monotonic() + max(0.0, delay)
        if safety_probe_due == 0.0 or due < safety_probe_due:
            safety_probe_due = due

    def capture_safety_screen():
        if not tmux_pane:
            return safety_recent, False

        try:
            result = subprocess.run(
                [tmux_bin, "capture-pane", "-p", "-J", "-t", tmux_pane],
                stdin=subprocess.DEVNULL,
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                timeout=0.5,
                check=False,
            )
        except (OSError, subprocess.TimeoutExpired):
            return None, True

        if result.returncode != 0:
            return None, True

        return strip_ansi(result.stdout.decode(errors="ignore")), True

    def run_match_probe():
        nonlocal match_probe_due, match_absent_since, match_latched, recent

        match_probe_due = 0.0
        screen, authoritative = capture_safety_screen()
        if not authoritative:
            return
        if screen is None:
            schedule_match_probe(0.2)
            return

        now = time.monotonic()
        if current_match_reason(screen):
            match_absent_since = None
            return

        if match_absent_since is None:
            match_absent_since = now
            schedule_match_probe(SAFETY_CHECK_DISMISS_CONFIRM_SECONDS)
            return

        if now - match_absent_since < SAFETY_CHECK_DISMISS_CONFIRM_SECONDS:
            schedule_match_probe(
                SAFETY_CHECK_DISMISS_CONFIRM_SECONDS
                - (now - match_absent_since)
            )
            return

        match_latched = False
        match_absent_since = None
        recent = ""
        notice("re-armed output match after it disappeared from the tmux pane")

    def mark_safety_handled(message: str):
        nonlocal safety_state, safety_probe_due, safety_confirmation_deadline
        nonlocal safety_absent_since

        safety_state = "handled"
        safety_probe_due = 0.0
        safety_confirmation_deadline = 0.0
        safety_absent_since = None
        notice(message)

    def send_safety_key(key: bytes) -> bool:
        try:
            os.write(master_fd, key)
            return True
        except OSError as e:
            if e.errno in (errno.EIO, errno.EBADF):
                mark_safety_handled("safety-check terminal closed")
                return False
            raise

    def begin_safety_navigation(active_index: int, keep_waiting_index: int):
        nonlocal safety_state, safety_confirmation_deadline
        nonlocal safety_current_index, safety_expected_index, safety_target_index
        nonlocal safety_confirmation_raw_recent, safety_confirmation_recent
        nonlocal safety_action_output_generation

        direction = 1 if active_index < keep_waiting_index else -1
        key = ARROW_DOWN_SEQUENCE if direction > 0 else ARROW_UP_SEQUENCE

        safety_state = "awaiting-selection"
        safety_current_index = active_index
        safety_expected_index = active_index + direction
        safety_target_index = keep_waiting_index
        safety_confirmation_raw_recent = ""
        safety_confirmation_recent = ""
        safety_action_output_generation = safety_output_generation
        safety_confirmation_deadline = (
            time.monotonic() + SAFETY_CHECK_CONFIRM_TIMEOUT_SECONDS
        )

        if not send_safety_key(key):
            return

        notice(
            "sent one arrow while waiting for Keep waiting selection confirmation"
        )

    def submit_confirmed_keep_waiting():
        nonlocal last_safety_return

        if not send_safety_key(RETURN_SEQUENCE):
            return

        last_safety_return = time.monotonic()
        mark_safety_handled(
            "sent Return after observing Keep waiting as the active option"
        )

    def rearm_safety_check():
        nonlocal safety_state, safety_raw_recent, safety_recent
        nonlocal safety_confirmation_raw_recent, safety_confirmation_recent
        nonlocal safety_absent_since

        safety_state = "armed"
        safety_raw_recent = ""
        safety_recent = ""
        safety_confirmation_raw_recent = ""
        safety_confirmation_recent = ""
        safety_absent_since = None

    def run_safety_probe():
        nonlocal safety_probe_due, safety_absent_since
        nonlocal safety_current_index, safety_expected_index
        nonlocal safety_confirmation_raw_recent, safety_confirmation_recent
        nonlocal safety_action_output_generation
        nonlocal safety_confirmation_deadline

        safety_probe_due = 0.0
        now = time.monotonic()

        if (
            safety_state == "awaiting-selection"
            and now >= safety_confirmation_deadline
        ):
            mark_safety_handled(
                "did not send Return because selection confirmation timed out"
            )
            return

        screen, authoritative = capture_safety_screen()
        if screen is None:
            if safety_state == "awaiting-selection":
                schedule_safety_probe(0.1)
            elif safety_state == "handled":
                schedule_safety_probe(0.2)
            return

        if safety_state == "armed":
            selection = safety_check_option_indices(screen)
            if selection is None:
                return

            active_index, keep_waiting_index = selection
            if (
                last_safety_return is not None
                and now - last_safety_return < args.safety_check_cooldown
            ):
                schedule_safety_probe(
                    args.safety_check_cooldown - (now - last_safety_return)
                )
                return

            if active_index == keep_waiting_index:
                submit_confirmed_keep_waiting()
            else:
                begin_safety_navigation(active_index, keep_waiting_index)
            return

        if safety_state == "awaiting-selection":
            if safety_output_generation <= safety_action_output_generation:
                return

            prompt_present = safety_check_prompt_present(screen)
            if authoritative and not prompt_present:
                mark_safety_handled(
                    "did not send Return because the safety-check menu disappeared"
                )
                return

            observed_active = latest_active_option_index(screen)
            if not authoritative:
                observed_active = latest_active_option_index(
                    safety_confirmation_recent
                )

            if observed_active == safety_current_index:
                return

            if observed_active != safety_expected_index:
                if observed_active is not None:
                    mark_safety_handled(
                        "did not send Return because the active option changed unexpectedly"
                    )
                return

            safety_current_index = observed_active

            if safety_current_index == safety_target_index:
                confirmation_text = screen if authoritative else safety_confirmation_recent
                if (
                    latest_active_keep_waiting_index(confirmation_text)
                    != safety_target_index
                ):
                    return
                submit_confirmed_keep_waiting()
                return

            direction = 1 if safety_current_index < safety_target_index else -1
            key = ARROW_DOWN_SEQUENCE if direction > 0 else ARROW_UP_SEQUENCE
            safety_expected_index = safety_current_index + direction
            safety_confirmation_raw_recent = ""
            safety_confirmation_recent = ""
            safety_action_output_generation = safety_output_generation
            safety_confirmation_deadline = (
                now + SAFETY_CHECK_CONFIRM_TIMEOUT_SECONDS
            )
            send_safety_key(key)
            return

        if safety_state == "handled" and authoritative:
            if safety_check_prompt_present(screen):
                safety_absent_since = None
                return

            if safety_absent_since is None:
                safety_absent_since = now
                schedule_safety_probe(SAFETY_CHECK_DISMISS_CONFIRM_SECONDS)
                return

            cooldown_finished = (
                last_safety_return is None
                or now - last_safety_return >= args.safety_check_cooldown
            )
            if (
                now - safety_absent_since >= SAFETY_CHECK_DISMISS_CONFIRM_SECONDS
                and cooldown_finished
            ):
                rearm_safety_check()
                return

            waits = [SAFETY_CHECK_DISMISS_CONFIRM_SECONDS]
            if last_safety_return is not None and not cooldown_finished:
                waits.append(args.safety_check_cooldown - (now - last_safety_return))
            schedule_safety_probe(max(0.01, min(waits)))

    try:
        while True:
            read_fds = [master_fd]

            if os.isatty(stdin_fd):
                read_fds.append(stdin_fd)

            select_timeout = 1.0
            now = time.monotonic()
            if match_probe_due > 0.0:
                select_timeout = min(select_timeout, max(0.0, match_probe_due - now))
            if safety_probe_due > 0.0:
                select_timeout = min(select_timeout, max(0.0, safety_probe_due - now))
            if safety_state == "awaiting-selection":
                select_timeout = min(
                    select_timeout,
                    max(0.0, safety_confirmation_deadline - now),
                )

            ready, _, _ = select.select(read_fds, [], [], select_timeout)

            if master_fd in ready:
                try:
                    data = os.read(master_fd, 8192)
                except OSError as e:
                    if e.errno == errno.EIO:
                        break
                    raise

                if not data:
                    break

                os.write(stdout_fd, data)
                last_output = time.monotonic()

                raw_text = output_decoder.decode(data)
                safety_text = strip_ansi(raw_text)
                text = raw_text if args.no_strip_ansi else safety_text

                recent = (recent + text)[-args.buffer:]
                safety_raw_recent = (safety_raw_recent + raw_text)[
                    -(args.buffer * 2) :
                ]
                safety_recent = strip_ansi(safety_raw_recent)[-args.buffer:]

                if not args.no_safety_check_return:
                    safety_output_generation += 1
                    if safety_state == "awaiting-selection":
                        safety_confirmation_raw_recent = (
                            safety_confirmation_raw_recent + raw_text
                        )[-(args.buffer * 2) :]
                        safety_confirmation_recent = strip_ansi(
                            safety_confirmation_raw_recent
                        )[-args.buffer:]

                    if (
                        safety_state != "armed"
                        or safety_check_prompt_present(safety_recent)
                    ):
                        schedule_safety_probe()

                reason = current_match_reason(recent)

                if reason:
                    if not match_latched:
                        send_reply(reason)
                        latched_notice_sent = False
                    elif not latched_notice_sent:
                        notice("suppressed reply: match still latched")
                        latched_notice_sent = True
                    match_latched = True
                    recent = ""

                if match_latched:
                    schedule_match_probe()

            if stdin_fd in ready:
                data = os.read(stdin_fd, 8192)
                if data:
                    forward_stdin(data)

            flush_pending_tmux_prefix_if_stale()

            if match_probe_due > 0.0 and time.monotonic() >= match_probe_due:
                run_match_probe()

            if (
                not args.no_safety_check_return
                and safety_probe_due > 0.0
                and time.monotonic() >= safety_probe_due
            ):
                run_safety_probe()

            if (
                safety_state == "awaiting-selection"
                and time.monotonic() >= safety_confirmation_deadline
            ):
                mark_safety_handled(
                    "did not send Return because selection confirmation timed out"
                )

            if args.idle > 0 and time.monotonic() - last_output >= args.idle:
                send_reply(f"idle {int(args.idle)}s")

            try:
                done_pid, status = os.waitpid(pid, os.WNOHANG)
                if done_pid == pid:
                    return exit_code_from_status(status)
            except ChildProcessError:
                break

    finally:
        if old_term is not None:
            try:
                termios.tcsetattr(stdin_fd, termios.TCSADRAIN, old_term)
            except OSError:
                pass

    try:
        _, status = os.waitpid(pid, 0)
        return exit_code_from_status(status)
    except ChildProcessError:
        return 0


if __name__ == "__main__":
    raise SystemExit(main())
